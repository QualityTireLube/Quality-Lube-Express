{
  "name": "print-client-app",
  "version": "1.0.1",
  "description": "Print Client - Native Mac Application",
  "main": "electron-main.js",
  "homepage": "./",
  "author": {
    "name": "Print Client Team",
    "email": "support@printclient.com"
  },
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "dev": "NODE_ENV=development electron .",
    "build": "npm run build:react && npm run build:electron",
    "build:react": "webpack --mode production",
    "build:electron": "electron-builder",
    "build:mac": "npm run build:react && electron-builder --mac",
    "build:mac-universal": "npm run build:react && electron-builder --mac --universal",
    "dist": "npm run build:react && electron-builder --publish=never",
    "dist:mac": "npm run build:react && electron-builder --mac --publish=never",
    "dist:dmg": "npm run build:react && electron-builder --mac dmg --publish=never",
    "dist:dmg-desktop": "npm run build:react && electron-builder --mac dmg --publish=never --dir=~/Desktop",
    "pack": "npm run build:react && electron-builder --dir",
    "pack:mac": "npm run build:react && electron-builder --mac --dir",
    "postinstall": "electron-builder install-app-deps"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.6.4",
    "@electron/rebuild": "^3.2.10",
    "webpack": "^5.89.0",
    "webpack-cli": "^5.1.4",
    "webpack-dev-server": "^4.15.1",
    "ts-loader": "^9.5.1",
    "html-webpack-plugin": "^5.6.0",
    "css-loader": "^6.8.1",
    "style-loader": "^3.3.3",
    "typescript": "^5.3.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@types/uuid": "^9.0.7"
  },
  "dependencies": {
    "electron-updater": "^6.1.7",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "@mui/material": "^5.15.0",
    "@mui/icons-material": "^5.15.0",
    "@emotion/react": "^11.11.0",
    "@emotion/styled": "^11.11.0",
    "react-draggable": "^4.4.5",
    "uuid": "^9.0.1"
  },
  "build": {
    "appId": "com.printclient.app",
    "productName": "Print Client",
    "directories": {
      "output": "~/Desktop",
      "buildResources": "assets"
    },
    "asarUnpack": [
      "*.py",
      "requirements.txt",
      "print_client_config.json"
    ],
    "files": [
      "electron-main.js",
      "preload.js",
      "print_dashboard_insepctionapp.py",
      "main_routes.py",
      "config_routes.py",
      "auth_routes.py",
      "print_job_routes.py",
      "printer_routes.py",
      "cups_routes.py",
      "config_manager.py",
      "auth_token_manager.py",
      "api_client.py",
      "print_queue.py",
      "requirements.txt",
      "print_client_config.json",
      "static/**/*",
      "node_modules/**/*",
      "!node_modules/*/{CHANGELOG.md,README.md,README,readme.md,readme}",
      "!node_modules/*/{test,__tests__,tests,powered-test,example,examples}",
      "!node_modules/*.d.ts",
      "!node_modules/.bin",
      "!**/*.{iml,o,hprof,orig,pyc,pyo,rbc,swp,csproj,sln,xproj}",
      "!.editorconfig",
      "!**/._*",
      "!**/{.DS_Store,.git,.hg,.svn,CVS,RCS,SCCS,.gitignore,.gitattributes}",
      "!**/{__pycache__,thumbs.db,.flowconfig,.idea,.vs,.nyc_output}",
      "!**/{appveyor.yml,.travis.yml,circle.yml}",
      "!**/{npm-debug.log,yarn.lock,.yarn-integrity,.yarn-metadata.json}"
    ],
    "extraResources": [
      {
        "from": "venv",
        "to": "venv",
        "filter": ["**/*"]
      }
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "target": [
        {
          "target": "dmg",
          "arch": ["x64", "arm64"]
        },
        {
          "target": "zip",
          "arch": ["x64", "arm64"]
        }
      ],
      "icon": "assets/icon.icns",
      "darkModeSupport": true,
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "assets/entitlements.mac.plist",
      "entitlementsInherit": "assets/entitlements.mac.plist",
      "artifactName": "${productName}-${version}-${arch}.${ext}"
    },
    "dmg": {
      "title": "Print Client ${version}",
      "icon": "assets/icon.icns",
      "background": "assets/dmg-background.png",
      "window": {
        "width": 540,
        "height": 380
      },
      "contents": [
        {
          "x": 130,
          "y": 220,
          "type": "file"
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ],
      "format": "ULFO",
      "sign": false,
      "artifactName": "${productName}-${version}-${arch}.${ext}"
    },
    "afterSign": "scripts/notarize.js"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/your-repo/print-client.git"
  },
  "keywords": [
    "print",
    "client",
    "electron",
    "mac",
    "desktop"
  ]
} 