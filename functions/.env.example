# Copy to .env for local emulator testing (do not commit .env with secrets).
# For production, set variables in Google Cloud Console on the printApi function,
# or use Firebase / Secret Manager per your team workflow.

API_KEY=
PRINT_CLIENT_TOKEN=

# Temporary: log every authenticated GET /api/print/jobs (User-Agent, Referer,
# X-Forwarded-For, etc.) to Cloud Logging. Set to 1, deploy, review, then remove.
LOG_GET_PRINT_JOBS=0
